{
    "name": "ziwot/cake-tezos",
    "description": "Tezos plugin for CakePHP",
    "type": "cakephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "steven j",
            "email": "hi@sjehan.net"
        }
    ],
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.0.1",
        "cakephp/authentication": "^3.3",
        "ziwot/pezos": "^0.2.2",
        "ziwot/tzkt-php-client": "^0.3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1",
        "phpstan/phpstan": "^2.1",
        "cakephp/cakephp-codesniffer": "^5.2",
        "slevomat/coding-standard": "^8.15",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "cakedc/cakephp-phpstan": "^4.1",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "CakeTezos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CakeTezos\\Test\\": "tests/",
            "TestApp\\": "tests/test_app/src/"
        }
    },
    "scripts": {
        "check": ["@test", "@stan", "@cs-check"],
        "cs-check": "phpcs --colors -p",
        "cs-fix": "phpcbf --colors -p",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-clover=clover.xml",
        "stan": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
"phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
